{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chaoticverse.local/schemas/artworks.schema.json",
  "title": "Artworks page (animations, music, gallery)",
  "description": "gallery[].authorId must match an id from about_us/people (scripters, artists, partners, exparticipants — not editors). Update $defs.galleryAuthorId.enum when people data changes.",
  "type": "object",
  "required": [
    "animations",
    "music",
    "gallery"
  ],
  "properties": {
    "animations": {
      "type": "array",
      "description": "YouTube video ids for the animation carousel",
      "items": {
        "type": "string",
        "minLength": 11,
        "maxLength": 12
      }
    },
    "music": {
      "type": "array",
      "description": "YouTube video ids for the music carousel",
      "items": {
        "type": "string",
        "minLength": 11,
        "maxLength": 12
      }
    },
    "gallery": {
      "type": "array",
      "description": "Artwork files in images/gallery/ grouped by author",
      "items": {
        "type": "object",
        "required": [
          "authorId",
          "files"
        ],
        "additionalProperties": false,
        "properties": {
          "authorId": {
            "$ref": "#/$defs/galleryAuthorId"
          },
          "files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "\\.webp$"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "galleryAuthorId": {
      "description": "Id from about_us/people (roles used on the artworks page: scripters, artists, partners, exparticipants)",
      "type": "string",
      "enum": [
        "TSyLizO",
